func syscall7 num arg1 arg2 arg3 arg4 arg5 arg6 do
	
	num arg1 arg2 arg3 arg4 arg5 arg6
	
	asm "sub rbp, 8"
	asm "mov r9, [rbp]"
	
	asm "sub rbp, 8"
	asm "mov r8, [rbp]"
	
	asm "sub rbp, 8"
	asm "mov r10, [rbp]"
	
	asm "sub rbp, 8"
	asm "mov rdx, [rbp]"
	
	asm "sub rbp, 8"
	asm "mov rsi, [rbp]"
	
	asm "sub rbp, 8"
	asm "mov rdi, [rbp]"
	
	asm "sub rbp, 8"
	asm "mov rax, [rbp]"
	
	asm "push rbp"
	asm "mov rbp, rsp"
	asm "syscall"
	asm "pop rbp"
	
	# this is how a error is detected
	asm "jc .syscall_error"
	
	asm "mov [rbp], rax"
	asm "add rbp, 8"
	asm "jmp .syscall_end"
	
	asm ".syscall_error:"
	asm "mov rax, -1"
	asm "mov [rbp], rax"
	asm "add rbp, 8"
	
	asm ".syscall_end:"
	# return is on the stack
end


func syscall1 num do
	num 0 0 0 0 0 0 syscall7
end

func syscall2 num arg1 do
	num arg1 0 0 0 0 0 syscall7
end

func syscall3 num arg1 arg2 do
	num arg1 arg2 0 0 0 0 syscall7
end

func syscall4 num arg1 arg2 arg3 do
	num arg1 arg2 arg3 0 0 0 syscall7
end

func syscall5 num arg1 arg2 arg3 arg4 do
	num arg1 arg2 arg3 arg4 0 0 syscall7
end

func syscall6 num arg1 arg2 arg3 arg4 arg5 do
	num arg1 arg2 arg3 arg4 arg5 0 syscall7
end


