	0x2000001 status syscall2
end


#
# fd - file descriptor to read from
# buf - buffer to write to
# len - number of bytes to attempt to read
#
# len - number of bytes read or -1 on error
#
func read fd buf len do
	0x2000003 fd buf len syscall4
end

#
# fd - file descriptor to write to
# buf - buffer to write from
# len - number of bytes to attempt to write
#
# len - number of bytes written, -1 on error
#
func write fd buf len do
	0x2000004 fd buf len syscall4
end

