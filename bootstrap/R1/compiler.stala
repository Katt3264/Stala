func file_read_line fd buffer length do
	
	while true do
		
		fd file_read_char let char
		buffer 0 !8
		
		char -1 != char "\n" ?8 != AND if
			buffer  char !8
			buffer ++ let buffer
		else
			ret
		end
		
		
	end
	
end

