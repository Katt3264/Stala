func > do
	asm "mov rcx, 0"
	asm "mov rdx, 1"
	
	# pop rax
	asm "sub rbp, 8"
	asm "mov rax, [rbp]"
	
	# pop rbx
	asm "sub rbp, 8"
	asm "mov rbx, [rbp]"
	
	asm "cmp rax, rbx"
	asm "cmovl rcx, rdx"
	
	# push rcx
	asm "mov [rbp], rcx"
	asm "add rbp, 8"
end

